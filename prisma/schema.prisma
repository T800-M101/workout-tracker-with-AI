// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  hashedRt  String?
  createdAt DateTime @default(now())

  workoutSessions WorkoutSession[]
  bodyMetrics     BodyMetric[]
  customExercises Exercise[]
}

model WorkoutSession {
  id       String    @id @default(uuid())
  title    String
  date     DateTime  @default(now())
  duration Int?
  notes    String?
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  workouts Workout[]
}

model Workout {
  id         String   @id @default(uuid())
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  sets       Int
  reps       Int
  weight     Float
  order      Int?
  
  // NEW: Add a notes field here too. 
  // Session notes are for "I felt tired today." 
  // Workout notes are for "The left shoulder felt a bit tight during this set."
  notes      String? 

  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Exercise {
  id           String   @id @default(uuid())
  name         String   @unique // Ex: "Bench Press", "Squats"
  category     String? // Ex: "Strength", "Cardio"
  muscleGroups String[] // Array of strings for targeted muscles
  equipment    String? // Ex: "Dumbbells", "Barbell"
  description  String?

  // Optional: Link to user if you want private exercises, 
  // or leave null for "Global/System" exercises
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Relation to the logs in sessions
  workouts Workout[]
}

model BodyMetric {
  id         String   @id @default(uuid())
  weight     Float // Current Weight
  height     Float? // 1.70
  bodyFat    Float? // % Fat
  muscleMass Float? // Muscle Mass
  waist      Float? // Waist in cm
  date       DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
