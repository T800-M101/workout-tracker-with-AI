generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Definition of Enums
enum ExerciseCategory {
  STRENGTH
  CARDIO
  HIIT
  FLEXIBILITY
  BALANCE 
}

// 2. User Model
model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  name            String?
  hashedRt        String?
  createdAt       DateTime         @default(now())
  
  workoutSessions WorkoutSession[]
  bodyMetrics     BodyMetric[]
  customExercises Exercise[]       @relation("UserExercises")
}

// 3. Training session (The global container)
model WorkoutSession {
  id        String    @id @default(uuid())
  title     String
  date      DateTime  @default(now())
  duration  Int?
  notes     String?
  
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  workouts  Workout[]
}

// 4. The log of a specific exercise within a session
model Workout {
  id         String         @id @default(uuid())
  exerciseId String
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  
  sets       Int
  reps       Int
  weight     Float
  order      Int?
  notes      String?
  
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// 5. The catalog of exercises (The definition)
model Exercise {
  id           String           @id @default(uuid())
  name         String           @unique 
  category     ExerciseCategory 
  muscleGroups String[]         
  equipment    String?          
  description  String?

  // Relación con el creador (opcional)
  userId       String?
  user         User?            @relation("UserExercises", fields: [userId], references: [id])
  
  workouts     Workout[]

  @@map("exercises")
}

// 6. Body metrics
model BodyMetric {
  id         String   @id @default(uuid())
  weight     Float
  height     Float?
  bodyFat    Float?
  muscleMass Float?
  waist      Float?
  date       DateTime @default(now())
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
